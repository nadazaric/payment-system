# SERVER
SERVER_PORT=5101
SERVER_SSL_ENABLED=true
SERVER_SSL_KEY_STORE=classpath:certs/keystore.p12
SERVER_SSL_KEY_STORE_PASSWORD=changeit
SERVER_SSL_KEY_STORE_TYPE=PKCS12
SERVER_SSL_KEY_ALIAS=wsbackend

# JWT
JWT_SECRET_KEY=change-me-local-development-secret

# WS POSTGRES
DB_PORT=5000
DB_NAME=sep-ws-db
DB_USERNAME=user
DB_PASSWORD=pass

# PSP
PSP_BASE_URL=https://localhost:5102/
PSP_MERCHANT_ID=MER-TEST0001
PSP_MERCHANT_PASSWORD=mrc_test_api_key_for_local_dev_12345
PSP_SELLER_REFERENCE=MAIN_SELLER
PSP_CURRENCY=RSD

# RABBITMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PAYMENT_NOTIFICATIONS_EXCHANGE=psp.payment.notifications.exchange
RABBITMQ_PAYMENT_NOTIFICATIONS_QUEUE=merchant.MER-TEST0001.payment-notifications
RABBITMQ_PAYMENT_NOTIFICATIONS_ROUTING_KEY=merchant.MER-TEST0001.payment.result

# OTHER
# Relative path from web-shop/back project root.
# If needed, replace with an absolute local path.
IMAGES_FOLDER_PATH=../../docker/vehicles